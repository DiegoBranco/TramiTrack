pipeline {
    agent any
    options {
        skipDefaultCheckout()
    }
    tools {
        dockerTool 'docker tramitrack'
    }
    environment {
        FRONTEND_IMAGE = "tramitrack-frontend"
        BACKEND_IMAGE = "tramitrack-backend"
        UNIT_TEST_IMAGE = "unit-tests"
        API_TEST_IMAGE = "api-tests"
        E2E_IMAGE = "e2e-tests"
        PERF_IMAGE = "perf-tests"
        DOCKER_API_VERSION = "1.44" 
    }
    stages {
        stage('Checkout') {
            steps {
                // Clean workspace before checkout to avoid permission conflicts
                deleteDir()
                // Trust the workspace directory to avoid "dubious ownership" errors
                sh 'git config --global --add safe.directory "*"'
                checkout([
                    $class: 'GitSCM',
                    branches: scm.branches,
                    extensions: [[$class: 'WipeWorkspace']],
                    userRemoteConfigs: scm.userRemoteConfigs
                ])
            }
        }
        stage('Build Backend') {
            steps {
                // Build backend from the `server` folder (Dockerfile uses default name)
                dir('tramitrack'){
                    sh '''
                        # Build backend using the server folder as build context so
                        # the server/package.json is used (avoid copying root package.json)
                        docker build \
                        -f server/Dockerfile \
                        -t ${BACKEND_IMAGE}:latest \
                        server
                        '''
                }

            }
        }
        stage('Build Frontend') {
            steps {
                // Build frontend from the `client` folder (uses client/Dockerfile)
                dir('tramitrack'){
                sh '''
                docker build \
                -f client/Dockerfile \
                -t ${FRONTEND_IMAGE}:build \
                client
                '''
                }
            }
        }
        /*
        stage('Frontend Production Image') {
            steps {
                sh '''
                docker build \
                -f Dockerfile.prod \
                -t ${FRONTEND_IMAGE}:prod \
                .
                '''
            }
        }
        */
        
        /*
        stage('Unit Tests') {
            steps {
                dir('tramitrack') {
                    sh '''
                    set -e
                    docker build -f tests/unit/Dockerfile.unit -t ${UNIT_TEST_IMAGE} .
                    UNIT_TEST_CONTAINER=$(docker create ${UNIT_TEST_IMAGE})
                    docker start -a ${UNIT_TEST_CONTAINER}
                    docker cp ${UNIT_TEST_CONTAINER}:/app/tests/unit/junit.xml tests/unit/junit.xml || true
                    docker rm -f ${UNIT_TEST_CONTAINER} >/dev/null 2>&1 || true
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'tramitrack/tests/unit/junit.xml'
                }
            }
        }
        
        
        stage('API Tests (Postman/Newman)') {
            steps {
                script {
                    dir('tramitrack'){
                            sh '''
                            set -e

                            API_NET="api-tests-net-${BUILD_NUMBER:-local}"
                            RUN_SUFFIX="${BUILD_NUMBER:-local}-${EXECUTOR_NUMBER:-0}"
                            MONGO_CONT="mongo-${RUN_SUFFIX}"
                            API_CONT="express-server-${RUN_SUFFIX}"
                            CI_LABEL="ci.tramitrack.api-tests=true"

                            OLD_CONTAINERS=$(docker ps -aq --filter "label=${CI_LABEL}" || true)
                            if [ -n "${OLD_CONTAINERS}" ]; then
                                docker rm -f ${OLD_CONTAINERS} >/dev/null 2>&1 || true
                            fi

                            OLD_NETWORKS=$(docker network ls -q --filter "label=${CI_LABEL}" || true)
                            if [ -n "${OLD_NETWORKS}" ]; then
                                docker network rm ${OLD_NETWORKS} >/dev/null 2>&1 || true
                            fi

                            cleanup() {
                                docker rm -f "${API_CONT}" "${MONGO_CONT}" >/dev/null 2>&1 || true
                                docker network rm "${API_NET}" >/dev/null 2>&1 || true
                            }

                            trap cleanup EXIT

                            docker build -f tests/api/Dockerfile.test -t ${API_TEST_IMAGE} tests/api

                            docker network create --label "${CI_LABEL}" "${API_NET}" >/dev/null 2>&1 || true

                            # 1. Arrancar Mongo
                            docker run -d --rm \
                            --name "${MONGO_CONT}" \
                            --label "${CI_LABEL}" \
                            --network "${API_NET}" \
                            --network-alias mongo \
                            mongo:4.4

                            # 2. Esperar a que Mongo esté listo antes de arrancar el backend
                            echo "Waiting for MongoDB to become ready..."
                            MONGO_RETRIES=15
                            MONGO_COUNT=0
                            until docker exec "${MONGO_CONT}" mongo --eval "db.runCommand(\'ping\').ok" --quiet 2>/dev/null; do
                                MONGO_COUNT=$((MONGO_COUNT+1))
                                if [ "$MONGO_COUNT" -ge "$MONGO_RETRIES" ]; then
                                    echo "ERROR: MongoDB did not become ready"
                                    docker logs "${MONGO_CONT}" || true
                                    exit 1
                                fi
                                sleep 2
                            done
                            echo "MongoDB ready"

                            # 3. Arrancar el backend
                            # Run backend without --rm so we can inspect logs if it exits
                            docker run -d \
                            --name "${API_CONT}" \
                            --label "${CI_LABEL}" \
                            --network "${API_NET}" \
                            --network-alias express-server \
                            -e SERVER_PORT=3001 \
                            -e MONGO_URI=mongodb://mongo:27017/tramitrack?authSource=admin \
                            ${BACKEND_IMAGE}:latest

                            SERVICE_CID=$(docker ps -q -f name="^${API_CONT}$")

                            # 4. Esperar a que el backend responda HTTP 200
                            RETRIES=30
                            COUNT=0
                            echo "Waiting for express-server to become healthy"
                            while [ "$COUNT" -lt "$RETRIES" ]; do
                                # Check if container is still present
                                CONT_EXISTS=$(docker ps -q -f name="^${API_CONT}$" || true)
                                if [ -z "${CONT_EXISTS}" ]; then
                                    echo "ERROR: ${API_CONT} container is not running (it may have exited). Dumping logs:"
                                    docker logs "${API_CONT}" || true
                                    docker logs "${MONGO_CONT}" || true
                                    exit 1
                                fi

                                # Try to hit the HTTP endpoint from inside the container
                                if docker exec "${API_CONT}" sh -c 'wget -q -T 2 -O /dev/null http://127.0.0.1:3001/' >/dev/null 2>&1; then
                                    echo "express-server is responding"
                                    break
                                fi

                                COUNT=$((COUNT+1))
                                sleep 2
                            done
                            if [ "$COUNT" -ge "$RETRIES" ]; then
                                echo "ERROR: express-server did not become healthy after ${RETRIES} attempts"
                                docker logs "${API_CONT}" || true
                                docker logs "${MONGO_CONT}" || true
                                exit 1
                            fi

                            # 5. Ejecutar pruebas Newman
                            API_IP=$(docker inspect -f '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' "${API_CONT}")

                            docker run --rm --network "${API_NET}" ${API_TEST_IMAGE} \
                            run coleccion.ci.json \
                            -e entorno.postman_environment.json \
                            --env-var "url=http://${API_IP}:3001"
                            '''
                    }
                }
            }
            post {
                failure {
                    echo 'AVISO: fallo en pruebas API o en la configuración'
                    }
            }
        }
        
        */
        stage('E2E Tests') {
            steps {
                script {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        dir('tramitrack') {
                            sh '''
                            set -e

                            # Configuración de nombres únicos
                            E2E_NET="e2e-net-${BUILD_NUMBER}"
                            RUN_SUFFIX="${BUILD_NUMBER}-${EXECUTOR_NUMBER}"
                            MONGO_CONT="e2e-mongo-${RUN_SUFFIX}"
                            API_CONT="e2e-api-${RUN_SUFFIX}"
                            FRONTEND_CONT="e2e-frontend-${RUN_SUFFIX}"
                            CI_LABEL="ci.tramitrack.e2e=true"

                            # Limpiar contenedores antiguos
                            OLD_CONTAINERS=$(docker ps -aq --filter "label=${CI_LABEL}" || true)
                            if [ -n "${OLD_CONTAINERS}" ]; then
                                docker rm -f ${OLD_CONTAINERS} >/dev/null 2>&1 || true
                            fi

                            OLD_NETWORKS=$(docker network ls -q --filter "label=${CI_LABEL}" || true)
                            if [ -n "${OLD_NETWORKS}" ]; then
                                docker network rm ${OLD_NETWORKS} >/dev/null 2>&1 || true
                            fi

                            # Función de limpieza
                            cleanup() {
                                echo "Limpiando contenedores E2E..."
                                docker rm -f ${FRONTEND_CONT} ${API_CONT} ${MONGO_CONT} >/dev/null 2>&1 || true
                                docker network rm ${E2E_NET} >/dev/null 2>&1 || true
                            }
                            trap cleanup EXIT

                            # Verificar archivos
                            echo "Verificando archivos de prueba en tests/e2e/:"
                            ls -la tests/e2e/

                            # Construir imagen de Cypress
                            echo "Construyendo imagen de E2E tests..."
                            docker build -f tests/e2e/Dockerfile.e2e -t ${E2E_IMAGE} tests/e2e

                            # Crear red aislada
                            echo "Creando red Docker..."
                            docker network create --label "${CI_LABEL}" ${E2E_NET}

                            # ============================================
                            # 1. LEVANTAR MONGODB
                            # ============================================
                            echo "Levantando MongoDB..."
                            docker run -d --rm \\
                                --name ${MONGO_CONT} \\
                                --label "${CI_LABEL}" \\
                                --network ${E2E_NET} \\
                                --network-alias mongo \\
                                mongo:4.4

                            echo "Esperando MongoDB..."
                            sleep 5

                            # ============================================
                            # 2. LEVANTAR BACKEND
                            # ============================================
                            echo "Levantando Backend desde ${BACKEND_IMAGE}:latest..."
                            docker run -d \\
                                --name ${API_CONT} \\
                                --label "${CI_LABEL}" \\
                                --network ${E2E_NET} \\
                                --network-alias api \\
                                -e SERVER_PORT=3001 \\
                                -e MONGO_URI=mongodb://mongo:27017/tramitrack \\
                                -e NODE_ENV=test \\
                                ${BACKEND_IMAGE}:latest

                            # Esperar a que el backend esté listo
                            echo "Esperando Backend..."
                            RETRIES=30
                            COUNT=0
                            until docker exec ${API_CONT} wget -q -T 2 -O /dev/null http://localhost:3001/ 2>/dev/null; do
                                COUNT=$((COUNT+1))
                                if [ $COUNT -ge $RETRIES ]; then
                                    echo "ERROR: Backend no responde después de $RETRIES intentos"
                                    echo "=== Logs del backend ==="
                                    docker logs ${API_CONT}
                                    echo "=== Logs de MongoDB ==="
                                    docker logs ${MONGO_CONT}
                                    exit 1
                                fi
                                echo "Esperando backend... ($COUNT/$RETRIES)"
                                sleep 2
                            done
                            echo "Backend listo ✓"

                            # ============================================
                            # 3. LEVANTAR FRONTEND (con mejor health check)
                            # ============================================
                            echo "Levantando Frontend desde ${FRONTEND_IMAGE}:build..."
                            
                            # Primero, verificar si wget está instalado, si no, instalar
                            docker run --rm ${FRONTEND_IMAGE}:build sh -c "which wget || apk add --no-cache wget" || true
                            
                            docker run -d \\
                                --name ${FRONTEND_CONT} \\
                                --label "${CI_LABEL}" \\
                                --network ${E2E_NET} \\
                                --network-alias frontend \\
                                -e VITE_API_URL=http://api:3001 \\
                                ${FRONTEND_IMAGE}:build \\
                                sh -c "apk add --no-cache wget && pnpm dev --host 0.0.0.0 --port 3000"

                            # Esperar a que el frontend esté listo (con múltiples estrategias)
                            echo "Esperando Frontend..."
                            RETRIES=30
                            COUNT=0
                            
                            # Estrategia 1: Esperar logs de Vite
                            echo "Esperando a que Vite compile..."
                            sleep 5  # Tiempo inicial para compilación
                            
                            # Estrategia 2: Verificar con wget (si está instalado)
                            while [ $COUNT -lt $RETRIES ]; do
                                if docker exec ${FRONTEND_CONT} wget -q -T 2 -O /dev/null http://localhost:3000 2>/dev/null; then
                                    echo "Frontend responde con wget ✓"
                                    break
                                fi
                                
                                # Estrategia 3: Verificar logs
                                if docker logs ${FRONTEND_CONT} 2>&1 | grep -q "ready in"; then
                                    echo "Frontend listo según logs ✓"
                                    sleep 2  # Dar tiempo extra después de "ready"
                                    break
                                fi
                                
                                COUNT=$((COUNT+1))
                                if [ $COUNT -ge $RETRIES ]; then
                                    echo "ERROR: Frontend no responde después de $RETRIES intentos"
                                    echo "=== Logs del frontend ==="
                                    docker logs ${FRONTEND_CONT}
                                    exit 1
                                fi
                                echo "Esperando frontend... ($COUNT/$RETRIES)"
                                sleep 2
                            done
                            
                            # Verificación final
                            echo "Verificando que el frontend está accesible desde la red..."
                            docker run --rm --network ${E2E_NET} curlimages/curl:latest curl -s -o /dev/null -w "%{http_code}" http://frontend:3000 || true
                            
                            echo "Frontend listo ✓"

                            # Pausa adicional para asegurar estabilidad
                            sleep 3

                            # ============================================
                            # 4. EJECUTAR PRUEBAS E2E
                            # ============================================
                            echo "=== Ejecutando pruebas E2E ==="
                            
                            # Verificar estructura
                            echo "Contenido de la imagen E2E:"
                            docker run --rm ${E2E_IMAGE} ls -la

                            # Ejecutar pruebas
                            echo "Ejecutando prueba completar-solicitud.cy.js..."
                            docker run --rm \\
                                --network ${E2E_NET} \\
                                -e CYPRESS_baseUrl=http://frontend:3000 \\
                                ${E2E_IMAGE} \\
                                cypress run --spec "completar-solicitud.cy.js" --headed --no-exit

                            echo "Ejecutando prueba smoke home.cy.js..."
                            docker run --rm \\
                                --network ${E2E_NET} \\
                                -e CYPRESS_baseUrl=http://frontend:3000 \\
                                ${E2E_IMAGE} \\
                                cypress run --spec "home.cy.js"

                            echo "=== Pruebas E2E completadas exitosamente ==="
                            '''
                        }
                    }
                }
            }
            post {
                unstable {
                    echo 'AVISO: Algunas pruebas E2E fallaron'
                }
                failure {
                    echo 'ERROR: Las pruebas E2E no pudieron ejecutarse'
                }
                always {
                    // Archivar resultados
                    script {
                        try {
                            sh 'mkdir -p e2e-results'
                            sh "docker cp e2e-frontend-${BUILD_NUMBER}-${EXECUTOR_NUMBER}:/e2e/cypress/videos e2e-results/ 2>/dev/null || true"
                            sh "docker cp e2e-frontend-${BUILD_NUMBER}-${EXECUTOR_NUMBER}:/e2e/cypress/screenshots e2e-results/ 2>/dev/null || true"
                            archiveArtifacts artifacts: 'e2e-results/**/*', allowEmptyArchive: true
                        } catch (Exception e) {
                            echo "No se pudieron archivar resultados: ${e.getMessage()}"
                        }
                    }
                }
            }
        }
        
