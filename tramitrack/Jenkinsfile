pipeline {
    agent any
    options {
        skipDefaultCheckout()
    }
    tools {
        dockerTool 'docker tramitrack'
    }
    environment {
        FRONTEND_IMAGE = "tramitrack-frontend"
        BACKEND_IMAGE = "tramitrack-backend"
        UNIT_TEST_IMAGE = "unit-tests"
        API_TEST_IMAGE = "api-tests"
        E2E_IMAGE = "e2e-tests"
        PERF_IMAGE = "perf-tests"
        DOCKER_API_VERSION = "1.44" 
    }
    stages {
        stage('Checkout') {
            steps {
                // Clean workspace before checkout to avoid permission conflicts
                deleteDir()
                // Trust the workspace directory to avoid "dubious ownership" errors
                sh 'git config --global --add safe.directory "*"'
                checkout([
                    $class: 'GitSCM',
                    branches: scm.branches,
                    extensions: [[$class: 'WipeWorkspace']],
                    userRemoteConfigs: scm.userRemoteConfigs
                ])
            }
        }
        stage('Build Backend') {
            steps {
                // Build backend from the `server` folder (Dockerfile uses default name)
                dir('tramitrack'){
                    sh '''
                    docker build \
                    -f server/Dockerfile \
                    -t ${BACKEND_IMAGE}:latest \
                    .
                    '''
                }

            }
        }
        stage('Build Frontend') {
            steps {
                // Build frontend from the `client` folder (uses client/Dockerfile)
                dir('tramitrack'){
                sh '''
                docker build \
                -f client/Dockerfile \
                -t ${FRONTEND_IMAGE}:build \
                client
                '''
                }
            }
        }
        /*
        stage('Frontend Production Image') {
            steps {
                sh '''
                docker build \
                -f Dockerfile.prod \
                -t ${FRONTEND_IMAGE}:prod \
                .
                '''
            }
        }
        */
        
        
        stage('Unit Tests') {
            steps {
                dir('tramitrack') {
                    sh '''
                    docker build -f tests/unit/Dockerfile.unit -t ${UNIT_TEST_IMAGE} tests/unit
                    docker run --rm ${UNIT_TEST_IMAGE}
                    '''
                }
            }
        }


stage('API Tests (Postman/Newman)') {
    steps {
        script {
            catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                dir('tramitrack') {
                    sh '''
                    # 1. Limpieza total de recursos previos [cite: 16, 17, 18]
                    docker stop express-server-test mongodb-test || true
                    docker network rm api-test-net || true
                    
                    # 2. Construir imagen de pruebas de Newman [cite: 1, 19]
                    docker build -f tests/api/Dockerfile.test -t ${API_TEST_IMAGE} tests/api
                    
                    # 3. Crear red para intercomunicación [cite: 20]
                    docker network create api-test-net
                    
                    # 4. Iniciar MongoDB 4.4 (SOLUCIÓN AL ERROR DE AVX/CPU) [cite: 21, 22]
                    # Cambiamos mongo:latest por mongo:4.4 porque es compatible con CPUs antiguas
                    echo "===== INICIANDO MONGODB 4.4 ====="
                    docker run -d --name mongodb-test --network api-test-net mongo:4.4
                    
                    echo "Esperando a que MongoDB inicie..."
                    sleep 10
                    
                    # 5. Iniciar Backend sobreescribiendo el comando (SOLUCIÓN A docker-compose: not found) [cite: 27, 28, 29]
                    # Se añade 'node index.js' al final para ignorar el script de pnpm que fallaba
                    echo "===== INICIANDO BACKEND ====="
                    docker run -d \
                        --name express-server-test \
                        --network api-test-net \
                        -e MONGO_URI=mongodb://mongodb-test:27017/tramitrack_test \
                        -e SERVER_PORT=3001 \
                        -e NODE_ENV=development \
                        -e DEBUG=* \
                        ${BACKEND_IMAGE}:latest node index.js
                    
                    # 6. Monitoreo de logs y espera de estabilidad [cite: 30, 31, 32]
                    docker logs -f express-server-test &
                    LOGS_PID=$!
                    echo "Esperando 15 segundos para inicialización..."
                    sleep 15
                    
                    # 7. Ejecutar pruebas de Postman con Newman [cite: 43, 44, 45]
                    # Forzamos la URL correcta mediante --env-var para evitar errores de resolución 
                    echo "===== EJECUTANDO PRUEBAS DE POSTMAN ====="
                    docker run --rm \
                        --network api-test-net \
                        ${API_TEST_IMAGE} \
                        run coleccion.postman_collection.json \
                        -e entorno.postman_environment.json \
                        --env-var "url=http://express-server-test:3001" \
                        --reporters cli,json \
                        --reporter-json-export test-results.json || true
                    
                    # 8. Limpiar al finalizar [cite: 51, 52, 53]
                    kill $LOGS_PID 2>/dev/null || true
                    docker stop express-server-test mongodb-test || true
                    docker network rm api-test-net || true
                    '''
                }
            }
        }
    }
}
                
        
        stage('E2E Tests') {
            steps {
                script {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        dir('tramitrack'){
                        sh '''
                        cleanup() {
                            docker rm -f frontend-e2e >/dev/null 2>&1 || true
                            docker network rm e2e-net >/dev/null 2>&1 || true
                        }

                        cleanup
                        trap cleanup EXIT

                        docker build -f tests/e2e/Dockerfile.e2e -t ${E2E_IMAGE} .
                        docker network create e2e-net
                        docker run -d --rm --name frontend-e2e --network e2e-net ${FRONTEND_IMAGE}:build pnpm dev --host 0.0.0.0 --port 3000
                        docker run --rm --network e2e-net -e CYPRESS_baseUrl=http://frontend-e2e:3000 ${E2E_IMAGE}
                        '''
                        }
                    }
                }
            }
            post {
                unstable {
                    echo 'AVISO: No se ejecutaron pruebas E2E o el contenedor de Cypress fallo'
                    }
                }
        } 
        
        
        stage('Performance Tests') {
        steps {
            script {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        dir('tramitrack'){
                        sh '''
                        docker build -f tests/performance/Dockerfile.performance -t ${PERF_IMAGE} tests/performance
                        docker run --rm ${PERF_IMAGE}
                        '''
                        }
                }
            }
        }
            post {
                unstable {
                echo 'AVISO: No se ejecutaron pruebas de Performance o los scripts de JMeter faltan'
                }
            }
        }
        
    }
    post {
    success {
        echo 'Pipeline finalizado: Proceso completado exitosamente'
        }
    failure {
        echo 'Pipeline finalizado: Error critico en el proceso'
        }
    always {
        script {
            try {
                sh 'docker image prune -f --filter "dangling=true"'
                sh 'docker image prune -f --filter "dangling=true"'
            } catch (Exception e) {
                echo "Warning: Failed to run docker prune: ${e.getMessage()}"
            }
        }
        }
    }
}