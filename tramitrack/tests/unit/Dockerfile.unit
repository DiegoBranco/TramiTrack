
FROM node:lts-alpine

# Instalamos pnpm una sola vez
RUN npm install -g pnpm@8

WORKDIR /app

# Copiamos los archivos de dependencias del paquete de tests
COPY tests/unit/package.json tests/unit/pnpm-lock.yaml* ./tests/unit/

# Copiamos el server para que los tests accedan al modelo
COPY server ./server

WORKDIR /app/tests/unit

# Permite resolver dependencias desde los node_modules del paquete de tests
ENV NODE_PATH=/app/tests/unit/node_modules

# Copiamos los archivos de tests y configuración
COPY tests/unit/ ./

# Instalamos TODAS las dependencias (incluyendo devDependencies donde vive Jest)
RUN pnpm install

# Comando para ejecutar jest
CMD ["pnpm", "exec", "jest", "--config=jest.config.cjs"]